     SUBJECT     : Sky condition observations for 2009
-->

<observation-set xmlns="http://vortex.cis.vtc.edu/xml/AOML_0.0"
  xmlns:xhtml="http://www.w3.org/1999/xhtml"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://vortex.cis.vtc.edu/xml/AOML_0.0 ../AOML/AOML.xsd">

  <location>
    <value>
      <lat-long-alt>+43.00-072.50+300</lat-long-alt>
    </value>
    <notes>
      <xhtml:p>Central Vermont, USA</xhtml:p>
    </notes>
  </location>
  <observer>Peter C. Chapin</observer>
  <notes>
    <xhtml:p>The temperature and humidity measurements shown here were all made with a La Crosse
      WS-7078SUF weather station.</xhtml:p>
  </notes>

  <observation>
    <localdatetime type="LDT" resolution="PT10M">
      <ISO>2009-04-05T21:45:00</ISO>
    </localdatetime>
    <skyconditions>
      <weather>
        <temperature>
          <value units="C">3.1</value>
        </temperature>
        <humidity>
          <value units="%">79</value>
        </humidity>
        <notes>
          <xhtml:p>Partly cloudy. The clouds that exist are relatively thin.</xhtml:p>
        </notes>
      </weather>
      <notes>
        <xhtml:p>The waxing moon is visible through the clouds and observable. Some stars are
          visible in other parts of the sky through the gaps in the clouds.</xhtml:p>
      </notes>
      <rating>3</rating>
    </skyconditions>
  </observation>

  <observation>
    <localdatetime type="LDT" resolution="PT10M">
      <ISO>2009-04-07T20:40:00</ISO>
    </localdatetime>
    <skyconditions>
      <weather>
        <temperature>
          <value units="C">-0.5</value>
        </temperature>
        <humidity>
          <value units="%">77</value>
        </humidity>
        <notes>
          <xhtml:p>Completely cloudy with light snow.</xhtml:p>
        </notes>
      </weather>
      <notes>
        <xhtml:p>The sky is unobservable.</xhtml:p>
      </notes>
      <rating>0</rating>
    </skyconditions>
  </observation>

  <observation>
    <localdatetime type="LST" resolution="PT10M">
      <ISO>2009-11-09T21:00:00</ISO>
    </localdatetime>
    <skyconditions>
      <weather>
        <temperature>
          <value units="C">3.6</value>
        </temperature>
        <humidity>
          <value units="%">69</value>
        </humidity>
        <notes>
          <xhtml:p>Perfectly clear</xhtml:p>
        </notes>
      </weather>
      <notes>
        <xhtml:p>It's a wonderful night. It is excellent conditions for observing deep sky objects </xhtml:p>
      </notes>
      <rating>4</rating>
    </skyconditions>
  </observation>

</observation-set>
