<observation-set xmlns="http://vortex.cis.vtc.edu/xml/AOML_0.0"
  xmlns:xhtml="http://www.w3.org/1999/xhtml"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://vortex.cis.vtc.edu/xml/AOML_0.0 ../AOML/AOML.xsd">

  <location>
    <value>
      <lat-long-alt>+43.00-072.50+300</lat-long-alt>
    </value>
    <notes>
      <xhtml:p>Central Vermont, USA</xhtml:p>
    </notes>
  </location>
  <observer>Peter C. Chapin</observer>
  <notes>
    <xhtml:p>The temperature and humidity measurements shown here were all made with a La Crosse
      WS-7078SUF weather station.</xhtml:p>
  </notes>

  <observation>
    <localdatetime type="LST" resolution="PT10M">
      <ISO>2010-01-02T22:00:00</ISO>
    </localdatetime>
    <skyconditions>
      <weather>
        <temperature>
          <value units="C">-10.2</value>
        </temperature>
        <humidity>
          <value units="%">78</value>
        </humidity>
        <notes>
          <xhtml:p>Completely cloudy and lightly snowing.</xhtml:p>
        </notes>
      </weather>
      <notes>
        <xhtml:p>No objects visible.</xhtml:p>
      </notes>
      <rating>0</rating>
    </skyconditions>
  </observation>

  <observation>
    <localdatetime type="LST" resolution="PT10M">
      <ISO>2010-01-18T21:50:00</ISO>
    </localdatetime>
    <skyconditions>
      <weather>
        <temperature>
          <value units="C">0.1</value>
        </temperature>
        <humidity>
          <value units="%">91</value>
        </humidity>
        <notes>
          <xhtml:p>Completely cloudy with light fog.</xhtml:p>
        </notes>
      </weather>
      <notes>
        <xhtml:p>No objects visible.</xhtml:p>
      </notes>
      <rating>0</rating>
    </skyconditions>
  </observation>

</observation-set>
